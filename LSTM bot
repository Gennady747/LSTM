import asyncio
import os
import numpy as np
from aiogram import Bot, Dispatcher
from aiogram.filters import Command
from aiogram.types import Message
import logging

# Проверяем, установлен ли statsmodels
try:
    from statsmodels.tsa.arima.model import ARIMA
    STATSMODELS_AVAILABLE = True
except ImportError:
    STATSMODELS_AVAILABLE = False

BOT_TOKEN = os.getenv("BOT_TOKEN")
if not BOT_TOKEN:
    raise ValueError("❌ BOT_TOKEN не найден!")

class ARIMAPredictor:
    """ARIMA модель для временных рядов"""
    
    def predict(self, values, steps=1):
        if len(values) < 5:
            # Если мало данных — линейная регрессия
            return self._linear_predict(values)
        
        try:
            # ARIMA(1,1,1) — простая но эффективная
            model = ARIMA(values, order=(1, 1, 1))
            fitted = model.fit()
            forecast = fitted.forecast(steps=steps)
            return float(forecast[0])
        except:
            # Fallback на линейную
            return self._linear_predict(values)
    
    def _linear_predict(self, values):
        """Линейная регрессия как запасной вариант"""
        if len(values) < 2:
            return values[0] if values else 0.0
        
        x = np.arange(len(values))
        coeffs = np.polyfit(x, values, 1)
        next_x = len(values)
        return coeffs[0] * next_x + coeffs[1]

# Выбираем модель
if STATSMODELS_AVAILABLE:
    model = ARIMAPredictor()
    MODEL_NAME = "ARIMA (statsmodels)"
else:
    # Fallback
    model = ARIMAPredictor()
    MODEL_NAME = "Linear Regression (fallback)"

bot = Bot(token=BOT_TOKEN, parse_mode="HTML")
dp = Dispatcher()

@dp.message(Command("start"))
async def cmd_start(message: Message):
    await message.answer(
        f"👋 <b>Прогнозный бот</b>\n\n"
        f"Модель: <code>{MODEL_NAME}</code>\n\n"
        f"<code>/predict 10 12 15 18 22 25</code>\n"
        f"Минимум 5 чисел для ARIMA"
    )

@dp.message(Command("predict"))
async def cmd_predict(message: Message):
    args = message.text.split()
    if len(args) < 2:
        await message.reply("❌ Укажите числа. Пример: <code>/predict 10 12 15 18 22</code>")
        return
    
    try:
        values = list(map(float, args[1:]))
        prediction = model.predict(values)
        
        # Доверительный интервал (примерный)
        std = np.std(values) if len(values) > 1 else 0
        lower = prediction - 1.96 * std
        upper = prediction + 1.96 * std
        
        await message.reply(
            f"📊 <b>Прогноз ARIMA</b>\n"
            f"━━━━━━━━━━━━━━\n"
            f"Данных: <code>{len(values)}</code>\n"
            f"Среднее: <code>{np.mean(values):.2f}</code>\n"
            f"Тренд: <code>{np.polyfit(range(len(values)), values, 1)[0]:+.4f}</code>\n\n"
            f"🎯 <b>Прогноз:</b> <code>{prediction:.4f}</code>\n"
            f"📉 Дов. интервал: [<code>{lower:.2f}</code> .. <code>{upper:.2f}</code>]"
        )
        
    except Exception as e:
        await message.reply(f"❌ Ошибка: {str(e)}")

@dp.message(Command("status"))
async def cmd_status(message: Message):
    status = "✅" if STATSMODELS_AVAILABLE else "⚠️ Fallback"
    await message.reply(
        f"📊 <b>Статус</b>\n"
        f"Модель: {MODEL_NAME}\n"
        f"Статус: {status}"
    )

async def main():
    logging.basicConfig(level=logging.INFO)
    print(f"🚀 Бот запущен | {MODEL_NAME}")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
