import asyncio
import os
import numpy as np
from aiogram import Bot, Dispatcher
from aiogram.filters import Command
from aiogram.types import Message
from aiogram.client.default import DefaultBotProperties
import logging

try:
    from statsmodels.tsa.arima.model import ARIMA
    from statsmodels.tsa.holtwinters import ExponentialSmoothing
    STATSMODELS = True
except ImportError:
    STATSMODELS = False

BOT_TOKEN = os.getenv("BOT_TOKEN")
if not BOT_TOKEN:
    raise ValueError("❌ BOT_TOKEN не найден!")

class SmartPredictor:
    """Автовыбор лучшей модели под данные"""
    
    def predict(self, values):
        n = len(values)
        
        if n < 3:
            return values[-1] if values else 0.0, "last_value"
        
        if not STATSMODELS or n < 8:
            return self._linear(values), "linear"
        
        x = np.arange(n)
        slope = np.polyfit(x, values, 1)[0]
        has_trend = abs(slope) > 0.01 * np.std(values)
        
        if n >= 6:
            diff1 = np.diff(values[:n//2])
            diff2 = np.diff(values[n//2:])
            seasonal = np.corrcoef(diff1, diff2[:len(diff1)])[0,1] > 0.5
        else:
            seasonal = False
        
        if seasonal and n >= 12:
            try:
                model = ExponentialSmoothing(
                    values, 
                    trend='add', 
                    seasonal='add', 
                    seasonal_periods=min(4, n//3)
                ).fit()
                return model.forecast(1)[0], "Holt-Winters"
            except:
                pass
        
        if has_trend:
            try:
                model = ARIMA(values, order=(1, 1, 1))
                fitted = model.fit()
                return fitted.forecast(1)[0], "ARIMA(1,1,1)"
            except:
                pass
        
        return self._linear(values), "linear"
    
    def _linear(self, values):
        x = np.arange(len(values))
        coeffs = np.polyfit(x, values, 1)
        return coeffs[0] * len(values) + coeffs[1]

model = SmartPredictor()

bot = Bot(
    token=BOT_TOKEN,
    default=DefaultBotProperties(parse_mode="HTML")
)

dp = Dispatcher()

@dp.message(Command("start"))
async def cmd_start(message: Message):
    await message.answer(
        "👋 <b>Прогнозный бот запущен!</b>\n\n"
        "Отправь: <code>/predict 10 12 15 18 22</code>\n"
        "Минимум 3 числа для анализа"
    )

@dp.message(Command("predict"))
async def cmd_predict(message: Message):
    args = message.text.split()
    if len(args) < 2:
        await message.reply("❌ Пример: <code>/predict 10 12 15 18 22</code>")
        return
    
    try:
        values = list(map(float, args[1:]))
        prediction, method = model.predict(values)
        
        # Оценка точности
        if len(values) >= 5:
            errors = []
            for i in range(3, len(values)):
                pred, _ = model.predict(values[:i])
                errors.append(abs(pred - values[i]))
            mae = np.mean(errors)
        else:
            mae = None
        
        text = (
            f"🔮 <b>Прогноз</b> <code>[{method}]</code>\n"
            f"━━━━━━━━━━━━━━\n"
            f"📊 Точек: <code>{len(values)}</code>\n"
        )
        
        if mae:
            text += f"📉 Ошибка: <code>±{mae:.3f}</code>\n"
        
        text += f"\n🎯 <b>Результат:</b> <code>{prediction:.4f}</code>"
        
        await message.reply(text)
        
    except Exception as e:
        await message.reply(f"❌ Ошибка: {str(e)}")

@dp.message(Command("status"))
async def cmd_status(message: Message):
    status = "✅ statsmodels" if STATSMODELS else "⚠️ numpy-only"
    await message.reply(f"📊 Статус: {status}")

async def main():
    logging.basicConfig(level=logging.INFO)
    # ← ИСПРАВЛЕНО: убрана переменная status, которая не была определена
    print(f"🚀 Бот запущен | Statsmodels: {'✅' if STATSMODELS else '❌'}")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
